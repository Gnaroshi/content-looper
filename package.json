{
  "name": "content-looper",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "contentdeck": "bin/contentdeck.mjs"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "showcase:dev": "VITE_GNAROSHI_SHOWCASE=1 vite --host 127.0.0.1",
    "showcase:electron": "concurrently -k -n web,app -c green,magenta \"VITE_GNAROSHI_SHOWCASE=1 vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && CONTENTDECK_ELECTRON_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.cjs\"",
    "test:showcase": "tsx --test src/showcase/mode.test.ts",
    "dev:web": "vite --host 127.0.0.1",
    "dev:api": "tsx watch server/index.ts",
    "app:dev": "concurrently -k -n api,web,app -c cyan,green,magenta \"npm:dev:api\" \"npm:dev:web\" \"wait-on http://127.0.0.1:5173 http://127.0.0.1:8787/api/health && CONTENTDECK_ELECTRON_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.cjs\"",
    "app:build:server": "tsc -p tsconfig.server.json",
    "app:pack": "npm run build && npm run app:build:server && node scripts/package-macos.mjs dir development",
    "app:install": "CONTENTDECK_INSTALL=1 npm run app:pack",
    "app:pack:test": "npm run build && npm run app:build:server && node scripts/package-macos.mjs dir test",
    "app:dmg": "npm run build && npm run app:build:server && node scripts/package-macos.mjs release release",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "tsx --test tests/*.test.ts tests/*.test.cjs"
  },
  "build": {
    "appId": "local.contentdeck.app",
    "productName": "ContentDeck",
    "protocols": [
      {
        "name": "ContentDeck media handoff",
        "schemes": ["contentdeck"]
      }
    ],
    "directories": {
      "output": "dist-mac"
    },
    "files": [
      "dist/**",
      "dist-server/**",
      "electron/**",
      "bin/**",
      "integration/**",
      "gnaroshi.app.json",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "Gnaroshi",
      "repo": "content-looper",
      "releaseType": "release"
    },
    "afterSign": "scripts/notarize-app.cjs",
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "integration",
        "to": "integration",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "integration/build-provenance.json",
        "to": "build-provenance.json"
      },
      {
        "from": "gnaroshi.app.json",
        "to": "gnaroshi.app.json"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.video",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dir"
      ]
    },
    "dmg": {
      "icon": "build/icon.icns"
    }
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "electron-updater": "^6.6.2",
    "fastify": "^5.8.5",
    "lucide-react": "^1.16.0",
    "motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  }
}
