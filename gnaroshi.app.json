{
  "schemaVersion": 1,
  "id": "content-looper",
  "displayName": "ContentDeck",
  "repository": "Gnaroshi/content-looper",
  "version": "0.1.0",
  "platforms": ["macos", "web"],
  "kind": "application",
  "bundleId": "local.contentdeck.app",
  "dataOwner": "content-looper",
  "capabilities": [
    "open-media-url",
    "open-session",
    "recent-sessions",
    "launch-player",
    "provider-status"
  ],
  "entrypoints": {
    "app": {
      "bundleId": "local.contentdeck.app",
      "displayName": "ContentDeck",
      "version": "0.1.0",
      "discovery": "bundle-id"
    },
    "cli": {
      "executable": "contentdeck",
      "versionSubcommand": ["--version"],
      "statusSubcommand": ["status", "--json"],
      "healthSubcommand": ["status", "--json"]
    },
    "localHttp": {},
    "deepLinks": []
  },
  "health": { "timeoutMs": 2000 },
  "icon": { "kind": "none" },
  "privacy": {
    "classification": "private-summary",
    "credentials": "provider-owned",
    "localPaths": "redacted"
  },
  "integration": {
    "contractVersion": 1,
    "minimumStudioVersion": "0.1.0",
    "purpose": "Open supported media for focused looping and resume provider-owned learning sessions.",
    "readOnly": true
  }
}
